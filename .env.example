# Якщо токен порожній — демо працює лише в браузері (без реального бота).
# Створіть бота через @BotFather та вставте токен сюди, щоб увімкнути нагадування в Telegram.
TELEGRAM_BOT_TOKEN=

# Назва салону (показується у заголовку Mini App)
SALON_NAME=Pawfect Studio

# Адреса студії (вставляється в нагадування за день до візиту)
SALON_ADDRESS=ul. Kwiatowa 12, Warszawa

# Telegram-нік грумера (для кнопки "Написати в Telegram" у картці клієнта)
GROOMER_TELEGRAM=anna_groomer

# Порт веб-сервера
PORT=5050
